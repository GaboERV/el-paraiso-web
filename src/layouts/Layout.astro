---
import '../styles/global.css';
import info from '../data/info.json';

interface Props {
	title?: string;
}

const { title = info.name } = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800&family=Fredoka:wght@400;500;600;700&display=swap" rel="stylesheet">
	</head>
	<body class="font-outfit bg-orange-50 text-gray-900 antialiased selection:bg-orange-500 selection:text-white flex flex-col min-h-screen">
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--font-outfit: 'Outfit', sans-serif;
		--font-display: 'Fredoka', sans-serif;
	}
	.font-outfit {
		font-family: var(--font-outfit);
	}
	.font-display {
		font-family: var(--font-display);
	}
</style>
