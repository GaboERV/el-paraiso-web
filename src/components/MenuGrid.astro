---
import MenuItem from './MenuItem.astro';
import menu from '../data/menu.json';
---

<section id="menu" class="py-20 lg:py-32 bg-white relative">
  <!-- Elemento decorativo superior -->
  <div class="absolute top-0 inset-x-0 h-16 bg-gradient-to-b from-orange-50 to-transparent"></div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center max-w-3xl mx-auto mb-16 lg:mb-24">
      <span class="text-orange-600 font-bold tracking-widest uppercase text-sm mb-4 block">Nuestro Menú</span>
      <h2 class="text-4xl lg:text-5xl font-display font-bold text-gray-900 mb-6">
        Antojitos para el alma
      </h2>
      <div class="w-24 h-1.5 bg-gradient-to-r from-orange-500 to-red-500 mx-auto rounded-full mb-8"></div>
      <p class="text-lg text-gray-600 font-outfit">
        Preparados al momento con los ingredientes más frescos. Disfruta del auténtico sabor mexicano a cualquier hora en un ambiente familiar imperdible.
      </p>
    </div>

    <!-- Grid de productos -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 lg:gap-8">
      {menu.map((item) => (
        <MenuItem 
          name={item.name} 
          description={item.description} 
          image={item.image} 
        />
      ))}
    </div>

    <div class="mt-16 text-center">
      <p class="text-gray-500 italic flex items-center justify-center gap-2">
        <span class="w-10 h-px bg-gray-300"></span>
        Y muchos antojitos más en nuestro mostrador
        <span class="w-10 h-px bg-gray-300"></span>
      </p>
    </div>
  </div>
</section>
