---
import info from '../data/info.json';
---

<section id="ubicacion" class="py-20 bg-gray-50 relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      
      <!-- Contenido de Contacto -->
      <div class="order-2 lg:order-1">
        <span class="text-orange-600 font-bold tracking-widest uppercase text-sm mb-4 block">Visítanos</span>
        <h2 class="text-4xl font-display font-bold text-gray-900 mb-6">
          Te esperamos con la familia completa
        </h2>
        
        <div class="bg-white rounded-[2rem] p-8 lg:p-10 shadow-xl border border-orange-100 relative">
          <!-- Decoración esquina -->
          <div class="absolute top-0 right-0 p-4 opacity-10 pointer-events-none">
            <svg class="w-24 h-24 text-orange-600" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
          </div>
          
          <ul class="space-y-8 relative z-10">
            <!-- Ubicación -->
            <li class="flex items-start gap-4">
              <div class="flex-shrink-0 w-12 h-12 rounded-full bg-orange-100 flex items-center justify-center text-orange-600">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <h4 class="font-bold text-gray-900 text-lg">Dirección</h4>
                <p class="text-gray-600 mt-1">{info.address.full}</p>
                <a href={`https://maps.google.com/?q=${info.address.full}`} target="_blank" rel="noopener noreferrer" class="text-orange-600 hover:text-red-500 font-medium text-sm mt-2 inline-block">Ver en Google Maps →</a>
              </div>
            </li>
            
            <!-- Horarios -->
            <li class="flex items-start gap-4">
              <div class="flex-shrink-0 w-12 h-12 rounded-full bg-orange-100 flex items-center justify-center text-orange-600">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <h4 class="font-bold text-gray-900 text-lg">Horarios</h4>
                <p class="text-gray-600 mt-1">{info.hours}</p>
              </div>
            </li>
            
            <!-- Contacto -->
            <li class="flex items-start gap-4">
              <div class="flex-shrink-0 w-12 h-12 rounded-full bg-orange-100 flex items-center justify-center text-orange-600">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <h4 class="font-bold text-gray-900 text-lg">Dudas o Pedidos</h4>
                <div class="flex flex-col gap-1 mt-1">
                  {info.phones.map(phone => (
                    <a href={`tel:${phone.tel}`} class="text-gray-600 hover:text-orange-600 font-medium text-xl transition-colors">
                      {phone.number}
                    </a>
                  ))}
                </div>
              </div>
            </li>
          </ul>
        </div>
      </div>
      
      <!-- Mapa Decorativo -->
      <div class="order-1 lg:order-2 h-[400px] lg:h-[600px] rounded-[3rem] overflow-hidden shadow-2xl relative border-8 border-white group">
        <div class="absolute inset-0 bg-gray-200">
          <iframe 
            src={`https://maps.google.com/maps?width=100%25&height=600&hl=en&q=${encodeURIComponent(info.address.full)}&t=&z=14&ie=UTF8&iwloc=B&output=embed`}
            width="100%" 
            height="100%" 
            frameborder="0" 
            style="border:0;" 
            allowfullscreen="" 
            aria-hidden="false" 
            tabindex="0"
            class="filter grayscale group-hover:grayscale-0 transition-all duration-700"
          ></iframe>
        </div>
        
        <div class="absolute bottom-6 left-6 right-6 bg-white/90 backdrop-blur-md p-4 rounded-2xl shadow-lg border border-white flex items-center gap-4">
          <div class="w-12 h-12 bg-gradient-to-br from-orange-400 to-red-500 rounded-full flex items-center justify-center text-white font-bold text-2xl shadow-inner">
            📍
          </div>
          <div>
            <p class="font-medium text-xs text-gray-500 uppercase">Nos encontramos en</p>
            <p class="font-bold text-gray-900 text-lg leading-tight">Omega, Georgia</p>
          </div>
        </div>
      </div>
      
    </div>
  </div>
</section>
