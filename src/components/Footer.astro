---
import info from '../data/info.json';
---

<footer class="bg-gray-900 border-t-8 border-orange-500 pt-16 pb-8 text-white relative overflow-hidden">
  <!-- Decoración BG -->
  <div class="absolute inset-0 opacity-5 pointer-events-none">
    <div class="absolute w-96 h-96 bg-white rounded-full blur-3xl -top-48 -right-48"></div>
    <div class="absolute w-96 h-96 bg-orange-500 rounded-full blur-3xl -bottom-48 -left-48"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-12">
      
      <!-- Columna 1: Branding -->
      <div class="col-span-1 md:col-span-2 lg:col-span-1">
        <a href="#" class="flex items-center gap-2 group mb-6">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-tr from-orange-500 to-red-500 flex items-center justify-center text-white font-bold text-2xl shadow-lg">
            EP
          </div>
          <span class="font-display font-bold text-2xl text-white tracking-tight">El Paraíso</span>
        </a>
        <p class="text-gray-400 font-outfit leading-relaxed">
          Traemos el auténtico sabor y la alegría de México a tu mesa. Un rincón familiar lleno de tradición y, sobre todo, mucho antojo.
        </p>
      </div>
      
      <!-- Columna 2: Enlaces -->
      <div>
        <h4 class="font-bold text-lg mb-6 text-orange-400 font-display">Navegación</h4>
        <ul class="space-y-3 font-outfit text-gray-400">
          <li><a href="#inicio" class="hover:text-white transition-colors flex items-center gap-2"><span class="text-orange-500">→</span> Inicio</a></li>
          <li><a href="#menu" class="hover:text-white transition-colors flex items-center gap-2"><span class="text-orange-500">→</span> Nuestro Menú</a></li>
          <li><a href="#ubicacion" class="hover:text-white transition-colors flex items-center gap-2"><span class="text-orange-500">→</span> Ubicación y Horarios</a></li>
        </ul>
      </div>
      
      <!-- Columna 3: Contacto -->
      <div>
        <h4 class="font-bold text-lg mb-6 text-orange-400 font-display">Contacto</h4>
        <ul class="space-y-3 font-outfit text-gray-400">
          <li class="flex items-start gap-3">
            <span class="text-orange-500 mt-1">📍</span>
            <span>{info.address.full}</span>
          </li>
          {info.phones.map(phone => (
             <li class="flex items-center gap-3">
              <span class="text-orange-500">📞</span>
              <a href={`https://wa.me/${phone.tel.replace('+','')}?text=Hola,%20me%20gustar%C3%ADa%20hacer%20un%20pedido`} target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">{phone.number}</a>
            </li>
          ))}
          <li class="flex items-center gap-3">
            <span class="text-orange-500">⏰</span>
            <span>{info.hours}</span>
          </li>
        </ul>
      </div>

      <!-- Columna 4: Redes Sociales -->
      <div>
        <h4 class="font-bold text-lg mb-6 text-orange-400 font-display">Síguenos</h4>
        <p class="text-gray-400 font-outfit mb-4">Descubre nuestras promociones y nuevos antojitos.</p>
        <div class="flex gap-4">
          <a href={`https://instagram.com/${info.socials.instagram.replace('@','')}`} target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-gray-800 flex items-center justify-center hover:bg-gradient-to-tr hover:from-orange-500 hover:to-red-500 text-white transition-all transform hover:-translate-y-1">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href={`https://facebook.com/${info.socials.facebook.replace('@','')}`} target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-gray-800 flex items-center justify-center hover:bg-blue-600 text-white transition-all transform hover:-translate-y-1">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/></svg>
          </a>
        </div>
      </div>
    </div>
    
    <!-- Copyright -->
    <div class="pt-8 border-t border-gray-800 text-center text-gray-500 font-outfit text-sm">
      <p>&copy; {new Date().getFullYear()} El Paraíso Frutería y más. Todos los derechos reservados.</p>
    </div>
  </div>
</footer>
