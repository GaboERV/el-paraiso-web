---
import info from '../data/info.json';
---

<section id="inicio" class="relative pt-28 pb-16 lg:pt-40 lg:pb-24 overflow-hidden bg-gradient-to-br from-orange-50 via-white to-red-50 min-h-[90vh] flex items-center">
  <!-- Decoraciones de fondo -->
  <div class="absolute top-0 right-0 -mr-20 -mt-20 w-80 h-80 rounded-full bg-orange-300 opacity-20 blur-3xl mix-blend-multiply"></div>
  <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-80 h-80 rounded-full bg-red-400 opacity-20 blur-3xl mix-blend-multiply"></div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-8 items-center">
      
      <!-- Contenido de Texto -->
      <div class="text-center lg:text-left max-w-2xl mx-auto lg:mx-0 font-outfit">
        <span class="inline-block py-1 pr-4 pl-1 mb-6 rounded-full bg-orange-100/80 border border-orange-200 text-orange-700 text-sm font-semibold tracking-wide flex items-center w-fit mx-auto lg:mx-0 shadow-sm backdrop-blur-sm">
          <span class="w-2 h-2 rounded-full bg-red-500 animate-pulse mr-2 ml-2"></span>
          ¡Comienza con Antojo!
        </span>
        
        <h1 class="text-5xl lg:text-7xl font-bold text-gray-900 leading-tight tracking-tight mb-6 font-display">
          Sabor de <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-500 to-red-600">Familia</span><br />
          en cada bocado
        </h1>
        
        <p class="text-lg text-gray-700 mb-8 leading-relaxed font-outfit max-w-lg mx-auto lg:mx-0">
          {info.welcomeMessage}
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <a href="#menu" class="px-8 py-4 bg-gradient-to-r from-orange-500 to-red-600 text-white font-bold rounded-full hover:shadow-xl hover:shadow-orange-500/20 hover:-translate-y-1 transition-all duration-300 transform text-center text-lg inline-flex items-center justify-center gap-2">
            <span>Ver nuestro Menú</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-8.707l-3-3a1 1 0 00-1.414 1.414L10.586 9H7a1 1 0 100 2h3.586l-1.293 1.293a1 1 0 101.414 1.414l3-3a1 1 0 000-1.414z" clip-rule="evenodd" />
            </svg>
          </a>
          <a href="#ubicacion" class="px-8 py-4 bg-white border-2 border-orange-200 text-orange-600 font-bold rounded-full hover:bg-orange-50 hover:border-orange-300 transition-all duration-300 text-center text-lg">
            Cómo llegar
          </a>
        </div>
        
        <div class="mt-8 flex items-center justify-center lg:justify-start gap-3">
          <div class="flex -space-x-3">
            <img class="w-10 h-10 rounded-full border-2 border-white object-cover" src="https://i.pravatar.cc/100?img=1" alt="Cliente" />
            <img class="w-10 h-10 rounded-full border-2 border-white object-cover" src="https://i.pravatar.cc/100?img=3" alt="Cliente" />
            <img class="w-10 h-10 rounded-full border-2 border-white object-cover" src="https://i.pravatar.cc/100?img=5" alt="Cliente" />
            <div class="w-10 h-10 rounded-full border-2 border-white bg-gray-100 flex items-center justify-center text-xs font-bold text-gray-600">
              +1k
            </div>
          </div>
          <span class="text-sm font-medium text-gray-600">Aprobado por familias perronas ⭐</span>
        </div>
      </div>
      
      <!-- Imagen principal / Placeholder Hero -->
      <div class="relative max-w-lg mx-auto lg:ml-auto w-full aspect-square md:aspect-[4/3] lg:aspect-square">
        <!-- Decoración circular -->
        <div class="absolute inset-0 bg-gradient-to-tr from-orange-400 to-red-500 rounded-full blur-2xl opacity-20 scale-95 origin-center animate-pulse-slow"></div>
        
        <!-- Contenedor principal de la imagen -->
        <div class="relative h-full w-full rounded-[2.5rem] p-3 bg-white/50 backdrop-blur-sm border border-white/60 shadow-2xl rotate-3 hover:rotate-0 transition-all duration-500 overflow-hidden transform group">
          <div class="absolute inset-0 bg-gradient-to-t from-gray-900/60 to-transparent z-10 rounded-[2rem] opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none"></div>
          
          <img 
            src="/image.png" 
            alt="El Paraíso Frutería" 
            class="w-full h-full object-cover rounded-[2rem]"
          />
        </div>
      </div>
      
    </div>
  </div>
</section>

<style>
  .animate-pulse-slow {
    animation: pulse 4s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
  .animate-bounce-slow {
    animation: bounce 3s infinite;
  }
  @keyframes bounce {
    0%, 100% {
      transform: translateY(-5%);
      animation-timing-function: cubic-bezier(0.8, 0, 1, 1);
    }
    50% {
      transform: translateY(0);
      animation-timing-function: cubic-bezier(0, 0, 0.2, 1);
    }
  }
</style>
